generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id                String              @id @default(uuid())
  email             String              @unique
  firstName         String?
  lastName          String?
  phone             String?
  company           String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  userAuths         UserAuths?
  UserVerifications UserVerifications[]
  UserTokens        UserTokens?
}

