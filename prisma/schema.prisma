model UserVerifications {
  id        String   @id @default(uuid())
  userId    String
  token     String
  deviceId  String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      Users    @relation(fields: [userId], references: [id])
}

model UserTokens {
  id           String   @id @default(uuid())
  userId       String   @unique
  refreshToken String
  accessToken  String
  deviceId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         Users    @relation(fields: [userId], references: [id])
}
